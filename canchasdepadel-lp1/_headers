# Cache-Control para assets estáticos: 1 año, immutable
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML: cache corto + revalidar
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Fonts (CDN externo, pero por si las hay locales)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Default para resto: 60s (URLs sin extensión sirven index.html, cache corto
# para que cambios de WA/tel se propaguen rápido)
/*
  Cache-Control: public, max-age=60, s-maxage=60, stale-while-revalidate=60
