# Cache-Control para assets estáticos: 1 año, immutable
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML: cache corto + revalidar
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Fonts (CDN externo, pero por si las hay locales)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Default para resto: HTML landing — cache 10 min browser, 30 min CF edge.
# Mejora Post-click QS (Google penaliza DYNAMIC). Si necesitas propagar
# cambio urgente: Purge Cache en CF dashboard (1 click).
/*
  Cache-Control: public, max-age=600, s-maxage=1800, stale-while-revalidate=3600
