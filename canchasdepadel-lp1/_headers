# Cache-Control para assets estáticos: 1 año, immutable
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML: cache corto + revalidar
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Fonts (CDN externo, pero por si las hay locales)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Default para resto: 1 hora
/*
  Cache-Control: public, max-age=3600
